# =========================================================
# Docker 构建忽略清单
# 任何不应进入镜像 build context 的文件都列在这里
# =========================================================

# --- Git / IDE ---
.git
.gitignore
.gitattributes
.github
.vscode
.idea
*.swp
*.swo

# --- Python 缓存 ---
__pycache__
**/__pycache__
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
.tox

# --- 虚拟环境 ---
.venv
venv
env
.env
.env.*

# --- 日志与运行时产物 ---
logs
**/logs
*.log

# --- 构建产物（builder 内现编现装，宿主机产物不入 context） ---
build
dist
*.egg-info
encrypted
.release-staging
pkg

# 模型由离线覆盖层单独打包，不进入 runtime 镜像构建上下文。
weights

# 基础镜像只需要固定版本的 ONNX Runtime wheel。
whl/*
!whl/onnxruntime_gpu-1.20.1-cp310-cp310-manylinux_2_27_x86_64.manylinux_2_28_x86_64.whl

# --- 测试与本地调试 ---
test
tests
demo
**/data
.scratch
datasets
output
vis

# --- 文档与说明 ---
*.md
docs

# --- Docker 自身 ---
Dockerfile
.dockerignore
docker-compose*.yml

# --- 操作系统垃圾 ---
.DS_Store
Thumbs.db

# --- 临时文件 ---
*.tmp
*.bak
*.orig
tmp
temp

# --- 不需要的根目录文件 ---
test.md
