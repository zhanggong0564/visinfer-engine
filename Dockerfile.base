# =========================================================
# VisInfer Engine (VIE) - 共享基础镜像（builder 环境）
#
# 这一层是 panel-label 与 scenes 两个服务镜像
# 的公共依赖环境：cuda 系统库 + 构建工具链 + 装好【全部 pip 依赖】的 venv + Cython。
# 它最慢最重（CUDA 运行库 + onnxruntime-gpu + Python 依赖），但在所有
# 场景间字节级一致，故抽出来只构建一次，各场景镜像 `FROM mobile_vision:base` 复用，
# 把「改代码/换场景」的镜像构建从几十分钟降到几分钟（只剩 Cython 编译插件 .so）。
#
# 何时需要重建本镜像：仅当 requirements.txt / onnxruntime 等【依赖】变化时。
#   业务代码（框架 + 插件）不进 base，留在各场景镜像 builder 阶段快速编译。
#
# 构建：bash scripts/release/build_base.sh
# 脚本会把本地 ORT wheel 目录作为 BuildKit named context 传入。
#
# 依赖说明：
#   - onnxruntime-gpu 1.20.1 (CUDA 12.x/cuDNN 9.x)：由 whl/ 本地 wheel 安装
# =========================================================

ARG BASE_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

FROM ${BASE_IMAGE} AS base

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/ \
    PIP_TRUSTED_HOST=mirrors.aliyun.com \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# 切换 apt 源为阿里云 + 安装 Python 3.10 与构建工具
RUN sed -i 's@//.*archive.ubuntu.com@//mirrors.aliyun.com@g; s@//security.ubuntu.com@//mirrors.aliyun.com@g' /etc/apt/sources.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        python3.10 \
        python3.10-venv \
        python3.10-dev \
        python3-pip \
        build-essential \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# 在 /opt/venv 创建独立 venv，所有依赖装到这里，便于各场景镜像多阶段复制
RUN python3.10 -m venv /opt/venv
ENV PATH=/opt/venv/bin:$PATH

# 复制依赖清单与部署提供的 CUDA 12.x ONNX Runtime wheel
COPY requirements.txt /tmp/requirements.txt
COPY --from=ort_wheel /onnxruntime_gpu-1.20.1-cp310-cp310-manylinux_2_27_x86_64.manylinux_2_28_x86_64.whl /tmp/

# 安装顺序说明：
#  1. 先用 --no-deps 安装部署提供的 onnxruntime-gpu 1.20.1 本地 wheel，避免从索引重复下载
#  2. 再装 requirements；已安装 wheel 满足精确版本要求，其依赖统一按清单解析并保持 numpy<2
# 不强升 pip：基础镜像自带 pip 已足够，强升会解析到最新版而镜像源对未同步新文件返回 403。
RUN pip install --upgrade setuptools wheel \
    && pip install /tmp/onnxruntime_gpu-1.20.1-cp310-cp310-manylinux_2_27_x86_64.manylinux_2_28_x86_64.whl --no-deps \
    && pip install -r /tmp/requirements.txt

# 业务模块经 Cython 编译为 .so（各场景镜像 builder 阶段执行 build_wheels.py），编译器随 venv 备好
RUN pip install "Cython>=3"
